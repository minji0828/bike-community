# Quick start with docker-compose local DB:
# 1) docker compose -f backend/docker-compose.local.yml up -d
# 2) SPRING_PROFILES_ACTIVE=docker ./gradlew bootRun

# Local development overrides (copy to application-local.yml and edit)
# IMPORTANT: Do not commit application-local.yml (contains secrets).

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/bikeoasis
    username: postgres
    password: "PUT-YOUR-DB-PASSWORD-HERE"

api:
  seoul:
    key: "PUT-YOUR-SEOUL-API-KEY-HERE"

app:
  jwt:
    # Must be 32+ bytes for HS256
    secret: "PUT-YOUR-APP-JWT-SECRET-32BYTES-MIN"
    # Optional: set to differentiate environments
    audience: "bikeoasis-mobile"
  cors:
    allowed-origins: "http://localhost:3000,http://localhost:3001"
    allowed-origin-patterns: ""

kakao:
  oauth:
    client-id: "PUT-YOUR-KAKAO-REST-API-KEY"
    client-secret: "PUT-YOUR-KAKAO-CLIENT-SECRET-IF-USED"
    # Comma-separated exact matches
    allowed-redirect-uris: "bikeoasis://oauth,kakaoxxxxx://oauth"

admin:
  api:
    key: "PUT-YOUR-ADMIN-API-KEY"

poi:
  fetch:
    onstartup: false

course:
  seed:
    gpx:
      onstartup: true
