SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR_RDS_HOST:5432/bikeoasis
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

SEOUL_API_KEY=CHANGE_ME
APP_JWT_SECRET=CHANGE_ME_32_BYTES_MINIMUM
APP_JWT_AUDIENCE=bikeoasis-mobile
APP_CORS_ALLOWED_ORIGINS=https://YOUR_DOMAIN

KAKAO_REST_API_KEY=CHANGE_ME
KAKAO_CLIENT_SECRET=CHANGE_ME
KAKAO_ALLOWED_REDIRECT_URIS=https://YOUR_DOMAIN/auth/kakao/callback

NEXT_PUBLIC_API_BASE_URL=https://YOUR_DOMAIN
NEXT_PUBLIC_KAKAO_CLIENT_ID=CHANGE_ME
NEXT_PUBLIC_KAKAO_REDIRECT_URI=https://YOUR_DOMAIN/auth/kakao/callback
NEXT_PUBLIC_KAKAO_MAP_JS_KEY=CHANGE_ME

ADMIN_API_KEY=CHANGE_ME

COURSE_GPX_STORAGE_MODE=s3
COURSE_GPX_S3_BUCKET=CHANGE_ME
COURSE_GPX_S3_PREFIX=courses/gpx
COURSE_GPX_S3_REGION=ap-northeast-2

# EC2 IAM Role 사용이 가장 권장됩니다.
# IAM Role을 쓰지 않는 경우에만 아래 키를 주입하세요.
# AWS_ACCESS_KEY_ID=CHANGE_ME
# AWS_SECRET_ACCESS_KEY=CHANGE_ME
